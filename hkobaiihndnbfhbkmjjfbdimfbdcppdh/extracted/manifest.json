{
  "manifest_version": 3,
  "name": "Securly Classroom",
  "short_name": "Securly",
  "minimum_chrome_version": "88.0.4324",
  "version": "1.36.1",
  "update_url": "https://crextnaut.securly.com/subscribers/defaultfrommanifest@securly.com/update-manifest.xml",
  "key": "",
  "icons": {
    "16": "logo16mono.png",
    "48": "logo48.png",
    "128": "logo128.png"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_icon": {
      "16": "logo16mono.png",
      "48": "logo48.png",
      "128": "logo128.png"
    },
    "default_title": "Securly Classroom"
  },
  "permissions": [
    "activeTab",
    "alarms",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess",
    "enterprise.deviceAttributes",
    "gcm",
    "geolocation",
    "identity",
    "identity.email",
    "idle",
    "nativeMessaging",
    "notifications",
    "offscreen",
    "scripting",
    "storage",
    "webRequest"
  ],
  "host_permissions": [
    "<all_urls>",
    "*://*/*"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "exclude_matches": ["*://richmondlp.com/*","*://*.eschooldata.com/*","*://*.arbitersports.com/*"],
      "js": ["cs.js"],
      "all_frames": true,
      "match_origin_as_fallback": true,
      "match_about_blank": true,
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [{
    "resources": ["*", "blocking/*", "fonts/*"],
    "matches": ["<all_urls>"],
    "extension_ids": ["ffndjmfjhjdamkocbfonjmoaecaflhga",
      "ljbaelmjoebdeieggdgiaaapncdicekm",
      "kgbbkfikebgafcfjgpdflkcoihjjlfmd",
      "jfbecfmiegcjddenjhlbhlikcbfmnafd"]
  }
  ]
}
