{
    "manifest_version": 3,
    "name": "Dyknow Cloud",
    "description": "The Chromebook extension for Dyknow Cloud.",
    "version": "7.11.6",
    "minimum_chrome_version": "102",
    "update_url": "https://crextnaut.securly.com/subscribers/defaultfrommanifest@securly.com/update-manifest.xml",
    "icons": {
        "128": "/images/icon-128.png"
    },
    "options_page": "ui/views/options.html",
    "background": {
        "service_worker": "worker.js",
        "type": "module"
    },
    "host_permissions": [
        "<all_urls>"
    ],
    "action": {
        "default_icon": {
            "19": "images/icon19.png",
            "38": "images/icon38.png"
        },
        "default_title": "Dyknow",
        "default_popup": "/ui/views/browserActionPopup.html"
    },
    "permissions": [
        "alarms",
        "management",
        "webNavigation",
        "activeTab",
        "identity",
        "identity.email",
        "enterprise.deviceAttributes",
        "storage",
        "tabs",
        "unlimitedStorage",
        "desktopCapture",
        "system.memory",
        "system.display",
        "<all_urls>",
        "https://accounts.google.com/*",
        "https://www.googleapis.com/*",
        "https://oauth.dydev.me/*",
        "https://api.dydev.me/*",
        "https://satellite01.dydev.me/*",
        "action"
    ],
    "key": "",
    "oauth2": {
        "client_id": "409057763755-jb5mnd10h57n21hvghmdl7kufq4mt29f.apps.googleusercontent.com",
        "scopes": [
            "https://www.googleapis.com/auth/userinfo.email"
        ]
    }
}